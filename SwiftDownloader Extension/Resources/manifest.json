{
  "manifest_version": 2,
  "name": "Fetchora",
  "description": "Intercepts downloads and sends them to Fetchora app",
  "version": "1.0",
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "contextMenus",
    "downloads",
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Fetchora"
  }
}
